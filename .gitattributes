# Auto detect text files and perform LF normalization
* text=auto

# Standardize line endings for web files
*.ts text eol=lf
*.tsx text eol=lf
*.js text eol=lf
*.html text eol=lf
*.css text eol=lf
*.json text eol=lf

# Denote binary files (images)
*.png binary
*.jpg binary
*.jpeg binary
*.svg text
*.ico binary
